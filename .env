# -----------------------------------------------------------------------------
# Backend 設定
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-change-in-production-min-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# Telegram Bot 設定
# -----------------------------------------------------------------------------
# 取得方式：
# 1. 在 Telegram 找 @BotFather
# 2. 傳送 /newbot 建立新機器人
# 3. 複製取得的 Token 貼到下面
TELEGRAM_BOT_TOKEN=7816814239:AAE0M1Zs0XUDVT_VOXqlJTFPNqMX5pYPPNA

# -----------------------------------------------------------------------------
# OpenAI Model 設定
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-api-key-1
OPENAI_BASE_URL=http://192.168.3.200:8317/v1
OPENAI_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Frontend 設定
# -----------------------------------------------------------------------------
# 後端 API 位址（Docker 網路內使用 service 名稱）
VITE_API_URL=http://backend:8000
